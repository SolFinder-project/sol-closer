# =============================================================================
# SOLcloser – Variables d'environnement (template)
# =============================================================================
# Copie ce fichier en .env.local et remplis les valeurs.
#   cp .env.example .env.local
# Ne committe jamais .env.local (déjà dans .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# Solana
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta
NEXT_PUBLIC_HELIUS_API_KEY=
NEXT_PUBLIC_SOLANA_RPC_URL=

# -----------------------------------------------------------------------------
# Fees & referral (Solana + EVM)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FEE_RECIPIENT_WALLET=
NEXT_PUBLIC_SERVICE_FEE_PERCENTAGE=20
NEXT_PUBLIC_REFERRAL_FEE_PERCENTAGE=10

# -----------------------------------------------------------------------------
# EVM / Base (Phase 2 – sweep dust)
# -----------------------------------------------------------------------------
ONEINCH_API_KEY=
NEXT_PUBLIC_EVM_FEE_RECIPIENT_WALLET=
NEXT_PUBLIC_BASE_RPC_URL=
# Testnet : mettre à true pour utiliser Base Sepolia au lieu de Base mainnet
# NEXT_PUBLIC_USE_BASE_TESTNET=false
# Optionnel pour Base Sepolia (défaut : https://sepolia.base.org)
# NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# Optionnel : autres chaînes EVM
# NEXT_PUBLIC_ETHEREUM_RPC_URL=
# NEXT_PUBLIC_POLYGON_RPC_URL=

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Required for server writes (reclaims, F1 registration, weekly_events bootstrap, NFT admin); never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# App (canonical URL for SEO, OG tags, sitemap — production: https://www.sol-pit.com)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Jeu F1
# -----------------------------------------------------------------------------
NEXT_PUBLIC_F1_TREASURY_WALLET=
F1_ADMIN_SECRET=

# -----------------------------------------------------------------------------
# APIs tierces (optionnel selon features)
# -----------------------------------------------------------------------------
JUPITER_API_KEY=
NEXT_PUBLIC_JUPITER_API_KEY=
RUGCHECK_API_KEY=
CRON_SECRET=

# -----------------------------------------------------------------------------
# Google (leaderboard, etc.)
# -----------------------------------------------------------------------------
GOOGLE_CREDENTIALS=
GOOGLE_SHEET_ID=

# -----------------------------------------------------------------------------
# Debug (dev uniquement)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_LOG_LEVEL=debug
# NEXT_PUBLIC_DEBUG=true
